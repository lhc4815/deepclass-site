# ============================
# 딥클래스 환경 변수 설정
# ============================
# 이 파일을 .env.local로 복사한 후 값을 채워주세요.
# cp .env.local.example .env.local

# --- 네이버 뉴스 검색 API ---
# 발급: https://developers.naver.com → 애플리케이션 등록 → 검색 API 선택
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- YouTube Data API v3 ---
# 발급: https://console.cloud.google.com → API 라이브러리 → YouTube Data API v3 사용 → API 키 생성
YOUTUBE_API_KEY=

# --- Supabase (DB + Auth) ---
# 발급: https://supabase.com → New Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
